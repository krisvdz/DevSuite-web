# ═══════════════════════════════════════════════════════════════════════════
# VARIÁVEIS DE AMBIENTE — Frontend (Vite)
# ═══════════════════════════════════════════════════════════════════════════
#
# 📚 CONCEITO: Variáveis de ambiente no Vite
#
# Vite expõe variáveis de ambiente com prefixo VITE_ para o código do browser.
# NUNCA coloque segredos (tokens, chaves privadas) aqui — o código frontend
# é público e qualquer pessoa pode ver pelo DevTools!
#
# Acesse com: import.meta.env.VITE_API_URL
# (diferente do Node que usa process.env)
#
# Em desenvolvimento com proxy Vite: deixe vazio ou use /api
# Em produção: aponte para a URL da sua API hospedada

# URL da API (deixe vazio para usar o proxy do Vite em dev)
VITE_API_URL=

# Ambiente
VITE_APP_ENV=development
